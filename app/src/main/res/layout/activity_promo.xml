<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="250dp" android:background="#FFCDD2">
        <ImageView android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp" android:src="@android:drawable/ic_menu_revert" app:tint="@color/black" android:background="@drawable/bg_white_rounded" android:padding="8dp" android:layout_margin="20dp" android:elevation="4dp"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_centerInParent="true" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medical Checks!" android:textColor="#C62828" android:textSize="28sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Diskon 20%" android:textColor="#D32F2F" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
        </LinearLayout>
    </RelativeLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="24dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Syarat &amp; Ketentuan" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1. Promo ini berlaku untuk semua pengguna baru Indonesian HealthyCare.\n\n2. Potongan harga 20% otomatis diaplikasikan saat pembayaran.\n\n3. Promo hanya berlaku untuk kategori Dokter Umum dan Spesialis Dalam.\n\n4. Berlaku hingga 31 Desember tahun ini." android:textColor="@android:color/darker_gray" android:textSize="14sp" android:lineSpacingExtra="6dp"/>
            <Button android:id="@+id/btnUsePromo" android:layout_width="match_parent" android:layout_height="55dp" android:text="Gunakan Promo Sekarang" android:textAllCaps="false" android:textColor="@color/white" android:backgroundTint="#4285F4" app:cornerRadius="12dp" android:layout_marginTop="32dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>