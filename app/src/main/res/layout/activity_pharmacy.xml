<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:background="@color/white" android:elevation="2dp">
        <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_revert" app:tint="@color/black" android:layout_centerVertical="true"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Toko Obat" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black" android:layout_centerInParent="true"/>
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" app:tint="@color/black" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
    </RelativeLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rekomendasi Untukmu" android:textStyle="bold" android:textColor="@color/black" android:textSize="16sp" android:layout_marginBottom="16dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="16dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/white" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                    <androidx.cardview.widget.CardView android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="#E3F2FD" app:cardElevation="0dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_add" app:tint="#4285F4"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paracetamol 500mg" android:textStyle="bold" android:textColor="@color/black" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 15.000 / strip" android:textColor="#D32F2F" android:textStyle="bold" android:textSize="14sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnAdd1" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Beli" android:textAllCaps="false" android:textColor="@color/white" android:backgroundTint="#4285F4" app:cornerRadius="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="16dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/white" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                    <androidx.cardview.widget.CardView android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="#FFF3E0" app:cardElevation="0dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_gallery" app:tint="#FF9800"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vitamin C 1000mg" android:textStyle="bold" android:textColor="@color/black" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 45.000 / botol" android:textColor="#D32F2F" android:textStyle="bold" android:textSize="14sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnAdd2" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Beli" android:textAllCaps="false" android:textColor="@color/white" android:backgroundTint="#4285F4" app:cornerRadius="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>