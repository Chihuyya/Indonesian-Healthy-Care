<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:background="@color/white" android:elevation="2dp">
        <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_revert" app:tint="@color/black" android:layout_centerVertical="true"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notifications" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black" android:layout_centerInParent="true"/>
    </RelativeLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today" android:textStyle="bold" android:textColor="@color/black" android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@drawable/bg_white_rounded" android:padding="16dp" android:layout_marginBottom="12dp" android:elevation="2dp" android:gravity="center_vertical">
                <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="20dp" app:cardBackgroundColor="#E8F5E9" app:cardElevation="0dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_today" app:tint="#4CAF50"/>
                </androidx.cardview.widget.CardView>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Booking Confirmed!" android:textStyle="bold" android:textColor="@color/black"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jadwal dengan dr. Daniel Michael besok jam 08:30 PM." android:textColor="@android:color/darker_gray" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@drawable/bg_white_rounded" android:padding="16dp" android:layout_marginBottom="12dp" android:elevation="2dp" android:gravity="center_vertical">
                <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="20dp" app:cardBackgroundColor="#FFCDD2" app:cardElevation="0dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_info_details" app:tint="#D32F2F"/>
                </androidx.cardview.widget.CardView>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Promo Medical Checkup" android:textStyle="bold" android:textColor="@color/black"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dapatkan diskon 20% untuk checkup pertama Anda." android:textColor="@android:color/darker_gray" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>